          "type": "array"
        },
        "position": {
          "minimum": 0,
          "title": "Position",
          "type": "integer"
        }
      },
      "required": [
        "keys",
        "position",
        "has_gaussian",
        "cached_gaussian"
      ],
      "title": "NumPyRngState",
      "type": "object"
    },
    "PythonRngState": {
