{
  "additionalProperties": false,
  "properties": {
    "adapter": {
      "default": "native-pytorch",
      "enum": [
        "native-pytorch",
        "huggingface-trainer",
        "pytorch-lightning",
        "pytorch-fsdp",
        "deepspeed-engine"
      ],
      "title": "Adapter",
      "type": "string"
    },
    "atol": {
      "const": 0.0,
      "default": 0.0,
      "title": "Atol",
      "type": "number"
    },
    "checkpoint_commit_seconds": {
      "anyOf": [
        {
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Checkpoint Commit Seconds"
    },
    "checkpoint_file_count": {
      "exclusiveMinimum": 0,
      "title": "Checkpoint File Count",
      "type": "integer"
    },
    "checkpoint_logical_bytes": {
      "exclusiveMinimum": 0,
      "title": "Checkpoint Logical Bytes",
      "type": "integer"
    },
    "checkpoint_path": {
      "title": "Checkpoint Path",
      "type": "string"
    },
    "checkpoint_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Checkpoint Sha256",
      "type": "string"
    },
    "checks_passed": {
      "exclusiveMinimum": 0,
      "title": "Checks Passed",
      "type": "integer"
    },
    "checks_total": {
      "exclusiveMinimum": 0,
      "title": "Checks Total",
      "type": "integer"
    },
    "code_commit": {
      "pattern": "^(?:[0-9a-f]{40}|unavailable)$",
      "title": "Code Commit",
      "type": "string"
    },
    "control_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Control Digest",
      "type": "string"
    },
    "control_evaluation_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Control Evaluation Digest",
      "type": "string"
    },
    "dependency_environment_path": {
      "const": "environment.json",
      "default": "environment.json",
      "title": "Dependency Environment Path",
      "type": "string"
    },
    "dependency_environment_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Dependency Environment Sha256",
      "type": "string"
    },
    "distributed_backend": {
      "anyOf": [
        {
          "const": "gloo",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Distributed Backend"
    },
    "distributed_implementation": {
      "anyOf": [
        {
          "enum": [
            "fully_shard",
            "zero-stage-2"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Distributed Implementation"
    },
    "distributed_strategy": {
      "anyOf": [
        {
          "enum": [
            "fsdp",
            "zero"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Distributed Strategy"
    },
    "distributed_world_size": {
      "anyOf": [
        {
          "const": 2,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Distributed World Size"
    },
    "distributed_zero_stage": {
      "anyOf": [
        {
          "const": 2,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Distributed Zero Stage"
    },
    "evidence_manifest_path": {
      "const": "evidence-manifest.json",
      "default": "evidence-manifest.json",
      "title": "Evidence Manifest Path",
      "type": "string"
    },
    "evidence_manifest_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Evidence Manifest Sha256",
      "type": "string"
    },
    "fault_scenario": {
      "default": "process_termination",
      "enum": [
        "process_termination",
        "process-kill",
        "managed_preemption",
        "checkpoint_restart"
      ],
      "title": "Fault Scenario",
      "type": "string"
    },
    "framework": {
      "default": "native-pytorch",
      "enum": [
        "native-pytorch",
        "transformers",
        "lightning",
        "pytorch-distributed",
        "deepspeed"
      ],
      "title": "Framework",
      "type": "string"
    },
    "framework_version": {
      "maxLength": 200,
      "minLength": 1,
      "title": "Framework Version",
      "type": "string"
    },
    "grace_period_seconds": {
      "anyOf": [
        {
          "maximum": 3600,
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Grace Period Seconds"
    },
    "graceful_exit_seconds": {
      "anyOf": [
        {
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Graceful Exit Seconds"
    },
    "html_report_path": {
      "const": "report.html",
      "default": "report.html",
      "title": "Html Report Path",
      "type": "string"
    },
    "issued_at": {
      "format": "date-time",
      "title": "Issued At",
      "type": "string"
    },
    "limitations": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Limitations",
      "type": "array"
    },
    "max_rpo_steps": {
      "minimum": 0,
      "title": "Max Rpo Steps",
      "type": "integer"
    },
    "original_worker_pid": {
      "exclusiveMinimum": 0,
      "title": "Original Worker Pid",
      "type": "integer"
    },
    "original_worker_pids": {
      "anyOf": [
        {
          "items": {
            "type": "integer"
          },
          "maxItems": 2,
          "minItems": 2,
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Original Worker Pids"
    },
    "persistence_contract_path": {
      "const": "persistence-contract.json",
      "default": "persistence-contract.json",
      "title": "Persistence Contract Path",
      "type": "string"
    },
    "persistence_contract_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Persistence Contract Sha256",
      "type": "string"
    },
    "preemption_signal": {
      "anyOf": [
        {
          "const": "SIGTERM",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Preemption Signal"
    },
    "qualification_profile": {
      "default": "exact-training-resume",
      "enum": [
        "exact-training-resume",
        "preemption-safe-training"
      ],
      "title": "Qualification Profile",
      "type": "string"
    },
    "recovery_worker_pid": {
      "exclusiveMinimum": 0,
      "title": "Recovery Worker Pid",
      "type": "integer"
    },
    "recovery_worker_pids": {
      "anyOf": [
        {
          "items": {
            "type": "integer"
          },
          "maxItems": 2,
          "minItems": 2,
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Recovery Worker Pids"
    },
    "report_path": {
      "const": "report.md",
      "default": "report.md",
      "title": "Report Path",
      "type": "string"
    },
    "result_path": {
      "const": "result.json",
      "default": "result.json",
      "title": "Result Path",
      "type": "string"
    },
    "resumed_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Resumed Digest",
      "type": "string"
    },
    "resumed_evaluation_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Resumed Evaluation Digest",
      "type": "string"
    },
    "rpo_steps": {
      "minimum": 0,
      "title": "Rpo Steps",
      "type": "integer"
    },
    "rpo_tokens": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Rpo Tokens"
    },
    "rto_seconds": {
      "exclusiveMinimum": 0.0,
      "title": "Rto Seconds",
      "type": "number"
    },
    "rtol": {
      "const": 0.0,
      "default": 0.0,
      "title": "Rtol",
      "type": "number"
    },
    "run_id": {
      "minLength": 1,
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "flashpilot-attestation-v1",
      "default": "flashpilot-attestation-v1",
      "title": "Schema Version",
      "type": "string"
    },
    "signature_status": {
      "const": "unsigned",
      "default": "unsigned",
      "title": "Signature Status",
      "type": "string"
    },
    "source_tree_state": {
      "enum": [
        "clean",
        "dirty",
        "unavailable"
      ],
      "title": "Source Tree State",
      "type": "string"
    },
    "verdict": {
      "const": "verified",
      "default": "verified",
      "title": "Verdict",
      "type": "string"
    },
    "verified_persisted_bytes": {
      "exclusiveMinimum": 0,
      "title": "Verified Persisted Bytes",
      "type": "integer"
    }
  },
  "required": [
    "framework_version",
    "run_id",
    "issued_at",
    "code_commit",
    "source_tree_state",
    "dependency_environment_sha256",
    "checkpoint_path",
    "checkpoint_sha256",
    "checkpoint_file_count",
    "checkpoint_logical_bytes",
    "persistence_contract_sha256",
    "evidence_manifest_sha256",
    "original_worker_pid",
    "recovery_worker_pid",
    "control_digest",
    "resumed_digest",
    "control_evaluation_digest",
    "resumed_evaluation_digest",
    "checks_passed",
    "checks_total",
    "rpo_steps",
    "max_rpo_steps",
    "rto_seconds",
    "verified_persisted_bytes",
    "limitations"
  ],
  "title": "RecoveryAttestationV1",
  "type": "object"
}
