{
  "$defs": {
    "DeepSpeedPolicyRequirement": {
      "additionalProperties": false,
      "properties": {
        "adapter": {
          "const": "deepspeed-engine",
          "title": "Adapter",
          "type": "string"
        },
        "backend": {
          "const": "gloo",
          "title": "Backend",
          "type": "string"
        },
        "fault": {
          "enum": [
            "checkpoint_restart",
            "rank_process_termination"
          ],
          "title": "Fault",
          "type": "string"
        },
        "fault_target_rank": {
          "anyOf": [
            {
              "enum": [
                0,
                1
              ],
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fault Target Rank"
        },
        "framework": {
          "const": "deepspeed",
          "title": "Framework",
          "type": "string"
        },
        "implementation": {
          "const": "zero-stage-2",
          "title": "Implementation",
          "type": "string"
        },
        "kind": {
          "const": "deepspeed-qualification",
          "title": "Kind",
          "type": "string"
        },
        "max_rpo_steps": {
          "maximum": 1000000,
          "minimum": 0,
          "title": "Max Rpo Steps",
          "type": "integer"
        },
        "max_rto_seconds": {
          "exclusiveMinimum": 0.0,
          "maximum": 86400.0,
          "title": "Max Rto Seconds",
          "type": "number"
        },
        "qualification_profile": {
          "const": "exact-training-resume",
          "title": "Qualification Profile",
          "type": "string"
        },
        "require_attestation": {
          "const": true,
          "default": true,
          "title": "Require Attestation",
          "type": "boolean"
        },
        "require_exact_recovery": {
          "const": true,
          "default": true,
          "title": "Require Exact Recovery",
          "type": "boolean"
        },
        "require_signed_attestation": {
          "default": false,
          "title": "Require Signed Attestation",
          "type": "boolean"
        },
        "required_status": {
          "const": "VERIFIED",
          "default": "VERIFIED",
          "title": "Required Status",
          "type": "string"
        },
        "requirement_id": {
          "maxLength": 80,
          "pattern": "^[a-z][a-z0-9-]*$",
          "title": "Requirement Id",
          "type": "string"
        },
        "strategy": {
          "const": "zero",
          "title": "Strategy",
          "type": "string"
        },
        "world_size": {
          "const": 2,
          "title": "World Size",
          "type": "integer"
        },
        "zero_stage": {
          "const": 2,
          "title": "Zero Stage",
          "type": "integer"
        }
      },
      "required": [
        "requirement_id",
        "qualification_profile",
        "max_rpo_steps",
        "max_rto_seconds",
        "kind",
        "framework",
        "adapter",
        "strategy",
        "implementation",
        "zero_stage",
        "backend",
        "world_size",
        "fault"
      ],
      "title": "DeepSpeedPolicyRequirement",
      "type": "object"
    },
