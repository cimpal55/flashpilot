    "missing_evidence": {
      "const": "fail",
      "default": "fail",
      "title": "Missing Evidence",
      "type": "string"
    },
    "policy_id": {
      "maxLength": 80,
      "pattern": "^[a-z][a-z0-9-]*$",
      "title": "Policy Id",
      "type": "string"
    },
    "requirements": {
      "items": {
        "discriminator": {
          "mapping": {
            "deepspeed-qualification": "#/$defs/DeepSpeedPolicyRequirement",
            "distributed-qualification": "#/$defs/DistributedPolicyRequirement",
            "hf-preemption-certification": "#/$defs/HFPreemptionPolicyRequirement",
            "hf-qualification": "#/$defs/HFPolicyRequirement",
            "lightning-qualification": "#/$defs/LightningPolicyRequirement",
            "native-qualification": "#/$defs/NativePolicyRequirement",
            "static-audit": "#/$defs/StaticAuditPolicyRequirement"
          },
          "propertyName": "kind"
        },
        "oneOf": [
          {
            "$ref": "#/$defs/StaticAuditPolicyRequirement"
          },
          {
            "$ref": "#/$defs/NativePolicyRequirement"
          },
          {
            "$ref": "#/$defs/HFPolicyRequirement"
          },
          {
            "$ref": "#/$defs/HFPreemptionPolicyRequirement"
          },
          {
            "$ref": "#/$defs/LightningPolicyRequirement"
          },
          {
            "$ref": "#/$defs/DistributedPolicyRequirement"
          },
          {
            "$ref": "#/$defs/DeepSpeedPolicyRequirement"
          }
        ]
      },
      "maxItems": 64,
      "minItems": 1,
      "title": "Requirements",
      "type": "array"
    },
    "schema_version": {
      "const": "flashpilot-qualification-policy-v1",
      "default": "flashpilot-qualification-policy-v1",
      "title": "Schema Version",
      "type": "string"
    },
    "unknown_state": {
      "const": "fail",
      "default": "fail",
      "title": "Unknown State",
      "type": "string"
    },
    "unlisted_evidence": {
      "const": "fail",
      "default": "fail",
      "title": "Unlisted Evidence",
      "type": "string"
    }
  },
  "required": [
    "policy_id",
    "requirements"
  ],
  "title": "QualificationPolicyV1",
  "type": "object"
