        "expected": {
          "minLength": 1,
          "title": "Expected",
          "type": "string"
        },
        "label": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "status": {
          "enum": [
            "pass",
            "fail"
          ],
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "check_id",
        "category",
        "label",
        "status",
        "expected",
        "actual"
      ],
      "title": "DistributedQualificationCheck",
      "type": "object"
    },
