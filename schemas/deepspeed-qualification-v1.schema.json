          "type": "string"
        },
        "final_global_step": {
          "exclusiveMinimum": 0,
          "title": "Final Global Step",
          "type": "integer"
        },
        "implementation": {
          "const": "zero-stage-2",
          "default": "zero-stage-2",
          "title": "Implementation",
          "type": "string"
        },
        "loaded_checkpoint_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Loaded Checkpoint Path"
        },
        "loss_history": {
          "items": {
            "type": "number"
          },
          "minItems": 1,
          "title": "Loss History",
          "type": "array"
        },
        "optimizer_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Optimizer Sha256",
          "type": "string"
        },
        "phase": {
          "enum": [
            "control",
            "checkpoint",
            "recovery"
          ],
          "title": "Phase",
          "type": "string"
        },
        "rank": {
          "minimum": 0,
          "title": "Rank",
          "type": "integer"
        },
        "scheduler_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Scheduler Sha256",
          "type": "string"
        },
        "schema_version": {
          "const": "flashpilot-deepspeed-rank-summary-v1",
          "default": "flashpilot-deepspeed-rank-summary-v1",
          "title": "Schema Version",
          "type": "string"
        },
        "strategy": {
          "const": "zero",
          "default": "zero",
          "title": "Strategy",
          "type": "string"
        },
        "torch_version": {
          "minLength": 1,
          "title": "Torch Version",
          "type": "string"
        },
        "trainable_state_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Trainable State Sha256",
          "type": "string"
        },
        "worker_pid": {
          "exclusiveMinimum": 0,
          "title": "Worker Pid",
          "type": "integer"
        },
        "world_size": {
          "const": 2,
          "default": 2,
          "title": "World Size",
          "type": "integer"
        },
        "zero_stage": {
          "const": 2,
          "default": 2,
          "title": "Zero Stage",
          "type": "integer"
        }
