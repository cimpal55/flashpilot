        "phase",
        "rank",
        "worker_pid",
        "final_global_step",
        "checkpoint_step",
        "checkpoint_saved",
        "checkpoint_loaded",
        "client_state_valid",
        "loss_history",
        "trainable_state_sha256",
        "evaluation_sha256",
        "optimizer_sha256",
        "scheduler_sha256",
        "collective_probe_sha256",
        "torch_version",
        "deepspeed_version"
