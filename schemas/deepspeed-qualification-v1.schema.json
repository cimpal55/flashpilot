    "DistributedQualificationCheck": {
      "additionalProperties": false,
      "properties": {
        "actual": {
          "minLength": 1,
          "title": "Actual",
          "type": "string"
        },
        "category": {
          "maxLength": 100,
          "minLength": 1,
          "title": "Category",
          "type": "string"
        },
        "check_id": {
          "pattern": "^[a-z][a-z0-9_.-]*$",
          "title": "Check Id",
          "type": "string"
