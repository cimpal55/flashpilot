{
  "$defs": {
    "AttestationRegistryArtifactV1": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "enum": [
            "recovery.attestation.json",
            "recovery.attestation.signature.json",
            "ed25519-public.pem"
          ],
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "size_bytes": {
          "exclusiveMinimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "path",
        "size_bytes",
        "sha256"
      ],
      "title": "AttestationRegistryArtifactV1",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "adapter": {
      "enum": [
        "native-pytorch",
        "huggingface-trainer",
        "pytorch-lightning",
        "pytorch-fsdp",
        "deepspeed-engine"
      ],
      "title": "Adapter",
      "type": "string"
    },
    "artifacts": {
      "items": {
        "$ref": "#/$defs/AttestationRegistryArtifactV1"
      },
      "maxItems": 3,
      "minItems": 3,
      "title": "Artifacts",
      "type": "array"
    },
    "attestation_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Attestation Sha256",
      "type": "string"
    },
    "fault_scenario": {
      "enum": [
        "process_termination",
        "process-kill",
        "managed_preemption",
        "checkpoint_restart",
        "rank_process_termination"
      ],
      "title": "Fault Scenario",
      "type": "string"
    },
    "framework": {
      "enum": [
        "native-pytorch",
        "transformers",
        "lightning",
        "pytorch-distributed",
        "deepspeed"
      ],
      "title": "Framework",
      "type": "string"
    },
    "issued_at": {
      "format": "date-time",
      "title": "Issued At",
      "type": "string"
    },
    "previous_entry_sha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Previous Entry Sha256"
    },
    "qualification_profile": {
      "enum": [
        "exact-training-resume",
        "preemption-safe-training"
      ],
      "title": "Qualification Profile",
      "type": "string"
    },
    "run_id": {
      "maxLength": 500,
      "minLength": 1,
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "flashpilot-attestation-registry-entry-v1",
      "default": "flashpilot-attestation-registry-entry-v1",
      "title": "Schema Version",
      "type": "string"
    },
    "sequence": {
      "minimum": 1,
      "title": "Sequence",
      "type": "integer"
    },
    "signature_artifact_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Signature Artifact Sha256",
      "type": "string"
    },
    "signing_key_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Signing Key Sha256",
      "type": "string"
    },
    "verification_check_ids": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Verification Check Ids",
      "type": "array"
    }
  },
  "required": [
    "sequence",
    "attestation_sha256",
    "signature_artifact_sha256",
    "signing_key_sha256",
    "qualification_profile",
    "framework",
    "adapter",
    "fault_scenario",
    "run_id",
    "issued_at",
    "verification_check_ids",
    "artifacts"
  ],
  "title": "AttestationRegistryEntryV1",
  "type": "object"
}
